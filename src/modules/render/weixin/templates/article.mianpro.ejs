<!-- 主容器 -->
<section style="
    margin: 0 auto;
    max-width: 680px;
    padding: 24px 16px;
    line-height: 1.6;
    color: #333333;
    background: #ffffff;
  ">
  
  <!-- 引导关注 -->
  <section style="
        margin: 0 auto 32px;
        padding: 16px;
        background: linear-gradient(135deg, #e6f3ff, #b3d9ff);
        border-radius: 8px;
        text-align: center;
      ">
    <section style="
          font-size: 14px;
          color: #3695f6;
          font-weight: 500;
        ">
      点击<span style="font-weight: bold; text-decoration: underline;">蓝字</span>订阅每日AI速递
    </section>
  </section>

  <!-- 目录部分 -->
  <section style="margin: 20px 0 32px;">
    <section style="
          margin: 20px auto;
          display: flex;
          justify-content: center;
          align-items: center;
        ">
      <section style="
            width: 40px;
            height: 13px;
            background: linear-gradient(to right, #e4f1fe, #3695f6);
          "></section>
      <section style="
            font-size: 18px;
            color: #3695f6;
            text-align: center;
            padding: 0 10px;
            font-weight: bold;
          ">
        文章目录
      </section>
      <section style="
            width: 40px;
            height: 13px;
            background: linear-gradient(to left, #e4f1fe, #3695f6);
          "></section>
    </section>

    <% for(var i=0; i<articles.length; i++) { var article=articles[i];%>
      <section style="
              margin: 12px 0;
              padding: 12px 16px;
              background: #f6fbff;
              border-left: 3px solid #3695f6;
              border-radius: 4px;
              cursor: pointer;
              transition: all 0.2s ease;
            "
            onmouseover="this.style.transform='translateX(4px)';this.style.boxShadow='2px 2px 8px rgba(54,149,246,0.1)'"
            onmouseout="this.style.transform='none';this.style.boxShadow='none'">
        <section style="
                  color: #3695f6;
                  font-size: 14px;
                  font-weight: 500;
                  line-height: 1.4;
                "><%=(i + 1).toString().padStart(2, '0' ) %>. <%=article.title.trim()%>
        </section>
      </section>
      <% }%>

    <!-- 主题部分 -->
    <section style="
          margin: 24px 0 0;
          padding: 20px;
          background: linear-gradient(135deg, #e6f3ff, #b3d9ff);
          border-radius: 8px;
          position: relative;
          box-shadow: 0 2px 8px rgba(179,217,255,0.2);
        ">
      <section style="
            font-size: 18px;
            font-weight: bold;
            color: #3695f6;
            margin-bottom: 8px;
            line-height: 1.4;
            text-align: center;
          ">
        🚀 今日AI速递
      </section>
      <section style="
            color: #7a9bc8;
            font-size: 14px;
            text-align: center;
          ">
        每日自动更新·欢迎订阅
      </section>
    </section>
  </section>

  <!-- 文章内容部分 -->
  <% for(var j=0; j<articles.length; j++) { var article=articles[j]; %>
    <section style="margin: 40px 0;">
      <!-- 文章头部 -->
      <section style="
            margin-bottom: 24px;
            padding: 20px;
            background: #f6fbff;
            border-radius: 8px;
            position: relative;
            box-shadow: 0 2px 8px rgba(54,149,246,0.1);
          ">
        <!-- 标题 -->
        <section style="
                  font-size: 20px;
                  font-weight: 600;
                  color: #3695f6;
                  margin-bottom: 8px;
                  line-height: 1.4;
                "><%=article.title.trim()%>
        </section>

        <!-- 发布日期 -->
<!--        <section style="-->
<!--                  color: #7a9bc8;-->
<!--                  font-size: 13px;-->
<!--                ">📅 <%=article.publishDate%>-->
<!--        </section>-->
      </section>

      <!-- 文章内容 -->
      <section style="
        padding: 20px;
        background: #f6fbff;
        border-radius: 8px;
        border-left: 3px solid #3695f6;
        box-shadow: 0 2px 8px rgba(54,149,246,0.1);
      ">
        <% var content=article.content || "" ; var paragraphs=content.split("<next_paragraph />");
        for(var i=0; i<paragraphs.length; i++) { var para=paragraphs[i].trim(); if(para.length> 0) {
         %>
          <section style="
            margin: 0 0 16px;
            color: #4a4a4a;
            font-size: 14px;
            line-height: 1.8;
            text-align: justify;
          "><%- para %>
          </section>
          <% }}%>
          <!-- 原文链接 -->
          <section style="
                  color: #7a9bc8;
                  font-size: 13px;
                  margin: 20px 0 10px;
                  text-align: left;
                ">
            <a href="<%= article.url %>" target="_blank" style="color:#7a9bc8; text-decoration:none;">🔗原文链接: <%= article.url.trim() %></a>
          </section>
      </section>
    </section>

    <!-- 文章分隔 -->
    <% if (j < articles.length - 1) {%>
      <section style="
              margin: 32px auto;
              text-align: center;
              color: #e6f0ff;
              font-size: 24px;
              position: relative;
            ">
        <section style="
                  position: absolute;
                  left: 0;
                  top: 50%;
                  width: 100%;
                  height: 1px;
                  background: #e6f0ff;
                  z-index: -1;
                "></section>
        <span style="background: #fff; padding: 0 16px;">···</span>
      </section>
      <% }%>
        <% }%>
</section>